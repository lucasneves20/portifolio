---
import { Font } from "astro:assets";
---

<Font cssVariable="--font-lato" preload />

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Lucas Neves | Portifolio</title>
  </head>
  <body>
    <header>
      <h1>Hello Recruiters</h1>

      <div>
        <h3>Lucas N. M. Sampaio</h3>
        <ul>
          <li>Main</li>
          <li>About</li>
          <li>Contact</li>
        </ul>
      </div>
    </header>

    <div class="container-slot">
      <slot />
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;

    box-sizing: border-box;

    font-family: var(--font-lato);
    background-color: #120f13;
    color: #eed;
  }

  h1 {
    font-size: 1.7rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;

    widht: 100vw;

    border-bottom: solid 1px #eed;
    padding: 1rem 2rem;
  }

  header div {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  header div ul {
    display: flex;
    gap: 1.5rem;
  }

  header div ul li {
    list-style: none;

    padding: 0.5rem 1rem;
    border-radius: 8px;
    cursor: pointer;

    transition:
      background-color 120ms ease-in,
      color 120ms ease-in;
  }

  header div ul li:hover {
    background-color: #eeeed0;
    color: #222;
  }

  .container-slot {
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
